{
  "name": "@ace-grid/core",
  "version": "1.0.17",
  "description": "Fast, MIT-licensed React data grid for editable, virtualized product workflows with sorting, filtering, pagination, theming, selection, and CSV I/O.",
  "type": "module",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": ">=18.2.0 <20.0.0",
    "react-dom": ">=18.2.0 <20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vitashev/ace-grid-core.git"
  },
  "bugs": {
    "url": "https://github.com/Vitashev/ace-grid-core/issues"
  },
  "homepage": "https://ace-grid.com/docs",
  "keywords": [
    "ace-grid",
    "react",
    "react-data-grid",
    "react-table",
    "data-grid",
    "javascript-data-grid",
    "editable-grid",
    "virtualized-grid",
    "datatable",
    "grid-component",
    "spreadsheet",
    "table",
    "typescript"
  ],
  "main": "./dist/core.cjs"
}
