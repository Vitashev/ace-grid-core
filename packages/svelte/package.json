{
  "name": "@ace-grid/svelte",
  "version": "1.0.5",
  "description": "Tier-neutral Svelte wrapper for Ace Grid Core, Pro, and Enterprise runtimes.",
  "type": "module",
  "svelte": "./dist/svelte.js",
  "module": "./dist/svelte.js",
  "types": "./dist/svelte.d.ts",
  "exports": {
    ".": {
      "types": "./dist/svelte.d.ts",
      "svelte": "./dist/svelte.js",
      "import": "./dist/svelte.js"
    },
    "./core": {
      "types": "./dist/svelte-core.d.ts",
      "svelte": "./dist/svelte-core.js",
      "import": "./dist/svelte-core.js"
    },
    "./pro": {
      "types": "./dist/svelte-pro.d.ts",
      "svelte": "./dist/svelte-pro.js",
      "import": "./dist/svelte-pro.js"
    },
    "./enterprise": {
      "types": "./dist/svelte-enterprise.d.ts",
      "svelte": "./dist/svelte-enterprise.js",
      "import": "./dist/svelte-enterprise.js"
    }
  },
  "scripts": {
    "build": "vite build && node ../../scripts/write-public-package-types.mjs svelte"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@ace-grid/core": "1.0.5",
    "@ace-grid/pro": "1.0.5",
    "@ace-grid/enterprise": "1.0.5",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@ace-grid/core": {
      "optional": true
    },
    "@ace-grid/pro": {
      "optional": true
    },
    "@ace-grid/enterprise": {
      "optional": true
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vitashev/ace-grid-core.git"
  },
  "bugs": {
    "url": "https://github.com/Vitashev/ace-grid-core/issues"
  },
  "homepage": "https://github.com/Vitashev/ace-grid-core#readme",
  "keywords": [
    "ace-grid",
    "svelte",
    "data-grid",
    "spreadsheet",
    "typescript"
  ]
}
