{
  "name": "@ace-grid/angular",
  "version": "1.0.5",
  "description": "Angular wrapper for Ace Grid Core, Pro, and Enterprise packages.",
  "type": "module",
  "module": "./dist/angular.js",
  "types": "./dist/angular.d.ts",
  "exports": {
    ".": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.js"
    },
    "./core": {
      "types": "./dist/angular-core.d.ts",
      "import": "./dist/angular-core.js"
    }
  },
  "scripts": {
    "build": "vite build && node ../../scripts/write-public-package-types.mjs angular"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@angular/common": "^20.0.0 || ^21.0.0",
    "@angular/core": "^20.0.0 || ^21.0.0",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vitashev/ace-grid-core.git"
  },
  "bugs": {
    "url": "https://github.com/Vitashev/ace-grid-core/issues"
  },
  "homepage": "https://github.com/Vitashev/ace-grid-core#readme",
  "keywords": [
    "ace-grid",
    "angular",
    "data-grid",
    "spreadsheet",
    "web-component"
  ]
}
